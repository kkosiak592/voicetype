{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoiceType",
  "version": "0.1.0",
  "identifier": "com.voicetype.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "settings",
        "title": "VoiceType Settings",
        "width": 480,
        "height": 400,
        "resizable": false,
        "visible": false
      },
      {
        "label": "pill",
        "url": "pill.html",
        "width": 200,
        "height": 44,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
